{
  "name": "worktree-navigator",
  "displayName": "Worktree Navigator",
  "description": "Register project roots and jump between their Git worktrees from a dedicated VS Code sidebar.",
  "version": "0.0.1",
  "publisher": "jisung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jisung-02/worktree-manager.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onView:worktreeNavigator.projects",
    "onCommand:worktreeNavigator.addRoot",
    "onCommand:worktreeNavigator.refresh",
    "onCommand:worktreeNavigator.openRegistryFile",
    "onCommand:worktreeNavigator.openRoot",
    "onCommand:worktreeNavigator.openWorktree",
    "onStartupFinished",
    "onCommand:worktreeNavigator.addSharedFile",
    "onCommand:worktreeNavigator.removeSharedFile",
    "onCommand:worktreeNavigator.syncSharedFiles",
    "onCommand:worktreeNavigator.setSharedFilesSyncMode",
    "onCommand:worktreeNavigator.openLocalIgnoreFile",
    "onCommand:worktreeNavigator.revealCurrentRoot",
    "onCommand:worktreeNavigator.revealCurrentWorktree",
    "onCommand:worktreeNavigator.openShortcutHelp"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "dev": "tsc -watch -p .",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.90.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "worktreeNavigator.addRoot",
        "title": "Worktree Navigator: Add Project Root",
        "icon": "$(add)"
      },
      {
        "command": "worktreeNavigator.refresh",
        "title": "Worktree Navigator: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "worktreeNavigator.openRegistryFile",
        "title": "Worktree Navigator: Edit Saved Roots",
        "icon": "$(edit)"
      },
      {
        "command": "worktreeNavigator.removeRoot",
        "title": "Worktree Navigator: Remove Project Root",
        "icon": "$(trash)"
      },
      {
        "command": "worktreeNavigator.openRoot",
        "title": "Worktree Navigator: Open Project Root"
      },
      {
        "command": "worktreeNavigator.openRootInNewWindow",
        "title": "Worktree Navigator: Open Project Root in New Window"
      },
      {
        "command": "worktreeNavigator.openWorktree",
        "title": "Worktree Navigator: Open Worktree"
      },
      {
        "command": "worktreeNavigator.openWorktreeInNewWindow",
        "title": "Worktree Navigator: Open Worktree in New Window"
      },
      {
        "command": "worktreeNavigator.createWorktree",
        "title": "Worktree Navigator: Create Worktree",
        "icon": "$(add)"
      },
      {
        "command": "worktreeNavigator.removeWorktree",
        "title": "Worktree Navigator: Remove Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "worktreeNavigator.handleRootClick",
        "title": "Worktree Navigator: Handle Root Click"
      },
      {
        "command": "worktreeNavigator.addSharedFile",
        "title": "Worktree Navigator: Add Shared File",
        "icon": "$(new-file)"
      },
      {
        "command": "worktreeNavigator.removeSharedFile",
        "title": "Worktree Navigator: Remove Shared File",
        "icon": "$(trash)"
      },
      {
        "command": "worktreeNavigator.syncSharedFiles",
        "title": "Worktree Navigator: Sync Shared Files",
        "icon": "$(sync)"
      },
      {
        "command": "worktreeNavigator.setSharedFilesSyncMode",
        "title": "Worktree Navigator: Set Shared Files Sync Mode",
        "icon": "$(settings-gear)"
      },
      {
        "command": "worktreeNavigator.openLocalIgnoreFile",
        "title": "Worktree Navigator: Edit Local Ignore File",
        "icon": "$(edit)"
      },
      {
        "command": "worktreeNavigator.revealCurrentRoot",
        "title": "Worktree Navigator: Reveal Current Root in Sidebar",
        "icon": "$(target)"
      },
      {
        "command": "worktreeNavigator.revealCurrentWorktree",
        "title": "Worktree Navigator: Reveal Current Worktree in Sidebar",
        "icon": "$(target)"
      },
      {
        "command": "worktreeNavigator.openShortcutHelp",
        "title": "Worktree Navigator: Open Shortcut Help",
        "icon": "$(keyboard)"
      }
    ],
    "keybindings": [
      {
        "command": "worktreeNavigator.revealCurrentRoot",
        "key": "ctrl+r",
        "mac": "cmd+r",
        "when": "workbenchState != empty"
      },
      {
        "command": "worktreeNavigator.openRoot",
        "key": "enter",
        "when": "view == worktreeNavigator.projects && viewItem == root && listFocus"
      },
      {
        "command": "worktreeNavigator.openRoot",
        "key": "enter",
        "when": "view == worktreeNavigator.projects && viewItem == directory && listFocus"
      },
      {
        "command": "worktreeNavigator.openWorktree",
        "key": "enter",
        "when": "view == worktreeNavigator.projects && viewItem == worktree && listFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "worktreeNavigator",
          "title": "Worktrees",
          "icon": "media/worktree.svg"
        }
      ]
    },
    "views": {
      "worktreeNavigator": [
        {
          "id": "worktreeNavigator.projects",
          "name": "Projects & Worktrees"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "worktreeNavigator.projects",
        "contents": "No project roots registered yet.\n[Add a project root](command:worktreeNavigator.addRoot)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "worktreeNavigator.addRoot",
          "when": "view == worktreeNavigator.projects",
          "group": "navigation"
        },
        {
          "command": "worktreeNavigator.refresh",
          "when": "view == worktreeNavigator.projects",
          "group": "navigation"
        },
        {
          "command": "worktreeNavigator.openRegistryFile",
          "when": "view == worktreeNavigator.projects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "worktreeNavigator.createWorktree",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "inline"
        },
        {
          "command": "worktreeNavigator.openRoot",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@1"
        },
        {
          "command": "worktreeNavigator.openRootInNewWindow",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@2"
        },
        {
          "command": "worktreeNavigator.createWorktree",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@3"
        },
        {
          "command": "worktreeNavigator.removeRoot",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@4"
        },
        {
          "command": "worktreeNavigator.openRoot",
          "when": "view == worktreeNavigator.projects && viewItem == directory",
          "group": "navigation@1"
        },
        {
          "command": "worktreeNavigator.openRootInNewWindow",
          "when": "view == worktreeNavigator.projects && viewItem == directory",
          "group": "navigation@2"
        },
        {
          "command": "worktreeNavigator.removeRoot",
          "when": "view == worktreeNavigator.projects && viewItem == directory",
          "group": "navigation@3"
        },
        {
          "command": "worktreeNavigator.openWorktree",
          "when": "view == worktreeNavigator.projects && viewItem == worktree",
          "group": "navigation@1"
        },
        {
          "command": "worktreeNavigator.removeWorktree",
          "when": "view == worktreeNavigator.projects && viewItem == worktree",
          "group": "navigation@3"
        },
        {
          "command": "worktreeNavigator.openWorktreeInNewWindow",
          "when": "view == worktreeNavigator.projects && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "worktreeNavigator.addSharedFile",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@5"
        },
        {
          "command": "worktreeNavigator.removeSharedFile",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@6"
        },
        {
          "command": "worktreeNavigator.syncSharedFiles",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@7"
        },
        {
          "command": "worktreeNavigator.setSharedFilesSyncMode",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@8"
        },
        {
          "command": "worktreeNavigator.openLocalIgnoreFile",
          "when": "view == worktreeNavigator.projects && viewItem == root",
          "group": "navigation@9"
        },
        {
          "command": "worktreeNavigator.openLocalIgnoreFile",
          "when": "view == worktreeNavigator.projects && viewItem == directory",
          "group": "navigation@4"
        },
        {
          "command": "worktreeNavigator.addSharedFile",
          "when": "view == worktreeNavigator.projects && viewItem == sharedFilesGroup",
          "group": "navigation@5"
        },
        {
          "command": "worktreeNavigator.removeSharedFile",
          "when": "view == worktreeNavigator.projects && viewItem == sharedFilesGroup",
          "group": "navigation@6"
        },
        {
          "command": "worktreeNavigator.syncSharedFiles",
          "when": "view == worktreeNavigator.projects && viewItem == sharedFilesGroup",
          "group": "navigation@7"
        },
        {
          "command": "worktreeNavigator.setSharedFilesSyncMode",
          "when": "view == worktreeNavigator.projects && viewItem == sharedFilesGroup",
          "group": "navigation@8"
        },
        {
          "command": "worktreeNavigator.removeSharedFile",
          "when": "view == worktreeNavigator.projects && viewItem == sharedFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Worktree Navigator",
      "properties": {
        "worktreeNavigator.openInNewWindow": {
          "type": "boolean",
          "default": false,
          "description": "Open a selected project root or worktree in a new window instead of reusing the current window."
        },
        "worktreeNavigator.doubleClickIntervalMs": {
          "type": "number",
          "default": 400,
          "minimum": 150,
          "maximum": 1000,
          "description": "Maximum interval used to treat two root-item clicks as a double click."
        },
        "worktreeNavigator.autoRefreshOnWindowFocus": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the tree when the VS Code window regains focus."
        },
        "worktreeNavigator.enableRootDoubleClick": {
          "type": "boolean",
          "default": true,
          "description": "Enable the experimental root double-click heuristic that opens the registered root on the second fast click."
        },
        "worktreeNavigator.sharedFiles": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Files relative to the main worktree that should be copied into other worktrees."
        },
        "worktreeNavigator.sharedFilesSyncMode": {
          "type": "string",
          "default": "manual",
          "enum": [
            "manual",
            "onCreate",
            "onCreateAndOpen",
            "off"
          ],
          "markdownEnumDescriptions": [
            "Sync only when you run the manual sync command.",
            "Sync automatically when a new worktree is created.",
            "Sync automatically on both worktree creation and opening.",
            "Disable both automatic and manual shared-file sync."
          ],
          "description": "Controls whether registered shared files sync on create, on create and open, manually, or not at all."
        }
      }
    }
  }
}
